enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

model Product {
  id String @id @default(cuid())

  productName String
  title       String?

  brand      String?
  categoryId String

  description String

  sku String @unique

  price         Float
  discountPrice Float?

  discountStartDate DateTime?
  discountEndDate   DateTime?

  stockQuantity Int @default(0)

  images String[]

  vendorId String

  status ProductStatus @default(PENDING)

  rejectReason String?

  approvedAt DateTime?
  rejectedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}
