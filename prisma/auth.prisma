enum Role {
  USER
  VENDOR
  ADMIN
  SUPERADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id       String     @id @default(uuid())
  name     String
  email    String     @unique
  phone    String     @unique
  age      Int
  password String
  role     Role       @default(USER)
  status   UserStatus @default(PENDING)

  // Vendor specific fields
  businessName    String?
  businessAddress String?

  // Profile fields
  image String?
  bio   String?

  resetToken       String?
  resetTokenExpiry DateTime?

  otp       String?
  otpExpiry DateTime?

  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
