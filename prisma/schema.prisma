// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  VENDOR
  ADMIN
  SUPERADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  phone     String     @unique
  age       Int
  password  String
  role      Role       @default(USER)
  status    UserStatus @default(PENDING)

  // Vendor specific fields
  businessName    String?
  businessAddress String?

  // Profile fields
  image String?
  bio   String?

  resetToken        String?
  resetTokenExpiry  DateTime?

  otp               String?
  otpExpiry         DateTime?

  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id               String    @id @default(uuid())
  name             String
  sku              Int?
  material         String?
  location         String?
  condition        String?
  status           Boolean   @default(true)
  image            String[]
  price            Float?
  specialPrice     Float?
  specialPriceFrom DateTime?
  specialPriceTo   DateTime?
  stockQuantity    Int?
  allowedCurrency  String[]
  length           Float?
  height           Float?
  width            Float?
  weight           Float?
  description      String?
  story            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  userId           String
  user             User      @relation(fields: [userId], references: [id])
}
