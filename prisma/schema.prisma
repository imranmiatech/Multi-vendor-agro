// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String    @id @default(uuid())
  fullName           String
  email              String    @unique
  password           String
  role               Role      @default(USER)
  hashedRefreshToken String?
  products           Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

///---------------------------product schema--------------------///

model Product {
  id               String    @id @default(uuid())
  name             String
  sku              Int?
  material         String?
  location         String?
  condition        String?
  status           Boolean   @default(true)
  image            String[]
  price            Float?
  specialPrice     Float?
  specialPriceFrom DateTime?
  specialPriceTo   DateTime?
  stockQuantity    Int?
  allowedCurrency  String[]
  length           Float?
  height           Float?
  width            Float?
  weight           Float?
  description      String?
  story            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  userId           String
  user             User      @relation(fields: [userId], references: [id])
}

enum CATEGORY {
  NEW_ITEM
  VINTAGE_ITEM
}

enum Role {
  ADMIN
  USER
}
